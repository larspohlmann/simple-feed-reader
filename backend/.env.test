# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

###> doctrine/doctrine-bundle ###
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_test.db"
###< doctrine/doctrine-bundle ###
MAINTENANCE_TOKEN='test-maintenance-token'

###> app/oauth ###
GOOGLE_OAUTH_CLIENT_ID='test-google-client-id'
GOOGLE_OAUTH_CLIENT_SECRET='test-google-client-secret'
APPLE_OAUTH_CLIENT_ID='test.apple.services.id'
APPLE_OAUTH_TEAM_ID='TESTTEAMID'
APPLE_OAUTH_KEY_ID='TESTKEYID1'
# Deliberately empty. Task 6 generates a throwaway EC key into a fixture file
# and points the Apple tests at it directly: a multi-line PEM inside a dotenv
# file is a portability trap. Regenerate that fixture with:
#   openssl ecparam -name prime256v1 -genkey -noout -out key.p8
APPLE_OAUTH_PRIVATE_KEY=''
APP_BACKEND_URL=http://localhost
###< app/oauth ###
