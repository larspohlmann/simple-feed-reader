###< symfony/framework-bundle ###

# Application repo: composer.lock must be committed (overrides user-global ignore)
!/composer.lock

# Symfony 7.4 auto-generates this config reference on every cache warmup.
# Build artifact, depends on installed bundles - not source.
/config/reference.php

###> phpunit/phpunit ###
/phpunit.xml
/.phpunit.cache/
###< phpunit/phpunit ###

# Legacy PHPUnit result cache (written when no cacheDirectory is configured, as
# with phpunit.dist.xml and phpunit-e2e.xml.dist). A build artifact, not source.
/.phpunit.result.cache

# The e2e config is committed as a .dist template, mirroring phpunit.dist.xml.
/phpunit-e2e.xml

# PHPMD ruleset is committed as phpmd.xml.dist; a local override is ignored.
/phpmd.xml

###> lexik/jwt-authentication-bundle ###
/config/jwt/*.pem
###< lexik/jwt-authentication-bundle ###
